func (s *RoomService) StartGame(ctx context.Context, code string, user *model.User) (*model.RoomSnapshot, error) {
	active, err := s.getOrLoadRoom(ctx, code)
	if err != nil {
		return nil, err
	}

	active.mu.Lock()
	defer active.mu.Unlock()

	host := s.findPlayerByUserID(active.players, user.ID)
	if host == nil {
		return nil, ErrPlayerNotInRoom
	}
	if !host.IsHost {
		return nil, ErrOnlyHostCanStart
	}
	if active.room.Status != model.RoomStatusWaiting {
		return nil, ErrRoomAlreadyPlaying
	}

	humanCount := 0
	for _, player := range active.players {
		if player.IsBot {
			continue
		}
		humanCount++
		if !player.IsReady {
			return nil, ErrPlayersNotReady
		}
	}
	if humanCount < 2 {
		return nil, ErrRoomRequiresPlayers
	}

	for len(active.players) < 4 {
		botSeat := nextSeat(active.players)
		bot := model.RoomPlayer{
			ID:        pkg.NewID("bot"),
			RoomID:    active.room.ID,
			Name:      botName(botSeat),
			Seat:      botSeat,
			IsHost:    false,
			IsReady:   true,
			IsBot:     true,
			Connected: true,
			JoinedAt:  time.Now().UTC(),
		}
		if err := s.roomRepo.AddPlayer(ctx, &bot); err != nil {
			return nil, err
		}
		active.players = append(active.players, bot)
	}
	sortPlayers(active.players)

	match := model.Match{
		ID:        pkg.NewID("match"),
		RoomID:    active.room.ID,
		Status:    "playing",
		CreatedAt: time.Now().UTC(),
		UpdatedAt: time.Now().UTC(),
	}
	if err := s.matchRepo.CreateMatch(ctx, &match); err != nil {
		return nil, err
	}

	dealer := rand.New(rand.NewSource(time.Now().UnixNano())).Intn(4)
	active.room.Status = model.RoomStatusPlaying
	active.room.MatchID = &match.ID
	active.room.UpdatedAt = time.Now().UTC()
	active.version++

	game := &GameState{
		Match:         match,
		RoomCode:      active.room.Code,
		Status:        "playing",
		Phase:         "setup",
		Dealer:        dealer,
		Round:         1,
		CurrentTurn:   dealer,
		Hands:         make([][]model.Tile, 4),
		Melds:         make([][]model.Meld, 4),
		Discards:      make([][]model.Tile, 4),
		Scores:        make([]int, 4),
		Logs:          []model.GameLogEntry{},
		LastMoveTime:  time.Now().UTC(),
	}
	for _, player := range active.players {
		game.Scores[player.Seat] = active.room.Settings.InitialScore
	}

	active.game = game
	s.initRoundLocked(ctx, active)
	return s.snapshotLocked(ctx, active)
}

func (s *RoomService) HandleDiscard(ctx context.Context, code string, user *model.User, tileKey string) error {
	if user == nil {
		return errors.New("user is required")
	}
	active, err := s.getOrLoadRoom(ctx, code)
	if err != nil {
		return err
	}

	active.mu.Lock()
	defer active.mu.Unlock()

	if active.game == nil {
		return ErrGameNotStarted
	}
	seat := seatForUser(active.players, user.ID)
	if seat < 0 {
		return ErrPlayerNotInRoom
	}
	if active.game.CurrentTurn != seat || active.game.Phase != "discard" {
		return ErrNotYourTurn
	}

	index := slices.IndexFunc(active.game.Hands[seat], func(tile model.Tile) bool {
		return tile.Key == tileKey
	})
	if index < 0 {
		return ErrInvalidGameAction
	}

	tile := active.game.Hands[seat][index]
	active.game.Hands[seat] = append(active.game.Hands[seat][:index], active.game.Hands[seat][index+1:]...)
	active.game.Discards[seat] = append(active.game.Discards[seat], tile)
	active.game.LastDiscard = &model.DiscardRef{Seat: seat, Tile: tile}
	active.game.Phase = "react"
	active.game.Pending = nil
	active.version++
	s.appendGameLogLocked(ctx, active, "discard", map[string]any{
		"seat": seat,
		"tile": tile,
	}, seatName(active.players, seat)+" 打出 "+tileLabel(tile))

	s.resolveReactionsLocked(ctx, active, seat, tile)
	_, err = s.snapshotLocked(ctx, active)
	return err
}

func (s *RoomService) HandleGameAction(ctx context.Context, code string, user *model.User, action model.PlayerActionType, tileKey string, chiIndex int) error {
	if user == nil {
		return errors.New("user is required")
	}
	active, err := s.getOrLoadRoom(ctx, code)
	if err != nil {
		return err
	}

	active.mu.Lock()
	defer active.mu.Unlock()

	if active.game == nil {
		return ErrGameNotStarted
	}
	seat := seatForUser(active.players, user.ID)
	if seat < 0 {
		return ErrPlayerNotInRoom
	}

	switch {
	case active.game.Pending != nil:
		if active.game.Pending.Seat != seat {
			return ErrInvalidGameAction
		}
		if err := s.applyPendingActionLocked(ctx, active, seat, action, tileKey, chiIndex); err != nil {
			return err
		}
	case action == model.ActionHu && active.game.CurrentTurn == seat && active.game.Phase == "discard":
		if !s.selfDrawWinLocked(active.game, seat) {
			return ErrInvalidGameAction
		}
		s.finishGameLocked(ctx, active, seat, true, "自摸")
	case action == model.ActionGangSelf && active.game.CurrentTurn == seat && active.game.Phase == "discard":
		if err := s.doSelfGangLocked(ctx, active, seat, tileKey); err != nil {
			return err
		}
	default:
		return ErrInvalidGameAction
	}

	_, err = s.snapshotLocked(ctx, active)
	return err
}

func (s *RoomService) initRoundLocked(ctx context.Context, active *ActiveRoom) {
	game := active.game
	game.Deck = shuffledDeck()
	game.DrawIndex = 0
	game.LastDiscard = nil
	game.Pending = nil
	game.Result = nil
	game.Phase = "setup"
	for seat := 0; seat < 4; seat++ {
		game.Hands[seat] = nil
		game.Melds[seat] = nil
		game.Discards[seat] = nil
	}
	for seat := 0; seat < 4; seat++ {
		for card := 0; card < 13; card++ {
			game.Hands[seat] = append(game.Hands[seat], game.Deck[game.DrawIndex])
			game.DrawIndex++
		}
		sortTiles(game.Hands[seat])
	}

	s.appendGameLogLocked(ctx, active, "round_start", map[string]any{
		"dealer": game.Dealer,
		"round":  game.Round,
	}, "第 1 局开始，庄家是 "+seatName(active.players, game.Dealer))
	s.beginTurnLocked(ctx, active, game.Dealer)
}

func (s *RoomService) beginTurnLocked(ctx context.Context, active *ActiveRoom, seat int) {
	game := active.game
	drawn, ok := s.drawTileLocked(game, seat)
	if !ok {
		s.finishDrawGameLocked(ctx, active)
		return
	}

	game.CurrentTurn = seat
	game.Pending = nil
	game.Phase = "discard"
	active.version++
	s.appendGameLogLocked(ctx, active, "draw", map[string]any{
		"seat": seat,
		"tile": drawn,
	}, seatName(active.players, seat)+" 摸牌")

	if active.players[seat].IsBot {
		version := active.version
		go s.runBotTurn(active.room.Code, seat, version)
	}
}

func (s *RoomService) runBotTurn(code string, seat int, version int64) {
	time.Sleep(900 * time.Millisecond)
	ctx := context.Background()
	active, err := s.getOrLoadRoom(ctx, code)
	if err != nil {
		return
	}

	active.mu.Lock()
	defer active.mu.Unlock()

	if active.version != version || active.game == nil || active.game.CurrentTurn != seat || active.game.Phase != "discard" {
		return
	}
	if s.selfDrawWinLocked(active.game, seat) {
		s.finishGameLocked(ctx, active, seat, true, "自摸")
		_, _ = s.snapshotLocked(ctx, active)
		return
	}
	if gangTile := s.firstSelfGangTileLocked(active.game, seat); gangTile != nil {
		if err := s.doSelfGangLocked(ctx, active, seat, gangTile.Key); err == nil {
			_, _ = s.snapshotLocked(ctx, active)
			return
		}
	}

	discard := s.pickBotDiscardLocked(active.game.Hands[seat])
	index := slices.IndexFunc(active.game.Hands[seat], func(tile model.Tile) bool {
		return tile.Key == discard.Key
	})
	if index < 0 {
		return
	}
	tile := active.game.Hands[seat][index]
	active.game.Hands[seat] = append(active.game.Hands[seat][:index], active.game.Hands[seat][index+1:]...)
	active.game.Discards[seat] = append(active.game.Discards[seat], tile)
	active.game.LastDiscard = &model.DiscardRef{Seat: seat, Tile: tile}
	active.game.Phase = "react"
	active.game.Pending = nil
	active.version++
	s.appendGameLogLocked(ctx, active, "discard", map[string]any{
		"seat": seat,
		"tile": tile,
	}, seatName(active.players, seat)+" 打出 "+tileLabel(tile))
	s.resolveReactionsLocked(ctx, active, seat, tile)
	_, _ = s.snapshotLocked(ctx, active)
}
